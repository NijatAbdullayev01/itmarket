# Local development only. Copy to .env; never reuse these values outside a
# developer workstation. Services bind to loopback by default.
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
# Optional deploy metadata injected by CI/CD for traceability.
# RELEASE_SHA=
# Required in production. Prometheus sends this as a Bearer token; store the
# real value in a secret manager and rotate it like any machine credential.
# METRICS_TOKEN=
APP_SECRET=local_application_secret_change_me_123456
PAYMENT_PROVIDER=mock
# POS fiscal receipt integration stays disabled until a legal provider is configured.
FISCAL_RECEIPT_PROVIDER=none
# Epoint hosted checkout uses merchant-configured result_url and these keys when
# PAYMENT_PROVIDER=epoint is selected.
# EPOINT_PUBLIC_KEY=
# EPOINT_PRIVATE_KEY=
# Optional merchant-confirmed installment mapping for Epoint hosted checkout.
# Comma-separated month list, e.g. 3,6,12
# EPOINT_INSTALLMENT_MONTHS=
# Optional minimum order total required before installment is offered.
# EPOINT_INSTALLMENT_MINIMUM=
STOREFRONT_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:3001
BACKOFFICE_ORIGIN=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Optional development seed administrator. Set both explicitly; no credential
# is supplied by the repository.
# SEED_STAFF_EMAIL=
# SEED_STAFF_PASSWORD=

POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=itmarket_local
POSTGRES_USER=itmarket_local
POSTGRES_PASSWORD=local_itmarket_postgres_only
DATABASE_URL=postgresql://itmarket_local:local_itmarket_postgres_only@localhost:5432/itmarket_local?schema=public

REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=local_itmarket_redis_only
REDIS_URL=redis://:local_itmarket_redis_only@localhost:6379/0

MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=itmarket_local
MINIO_ROOT_PASSWORD=local_itmarket_minio_only_ChangeOutsideLocal
MINIO_BUCKET=itmarket-local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=itmarket_local
S3_SECRET_KEY=local_itmarket_minio_only_ChangeOutsideLocal
S3_BUCKET=itmarket-local
S3_FORCE_PATH_STYLE=true

MAILPIT_BIND_ADDRESS=127.0.0.1
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=ITMarket Local <no-reply@itmarket.local>
